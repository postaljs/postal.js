{
    "name": "postal-transport-serviceworker",
    "version": "0.0.1",
    "description": "ServiceWorker transport for postal — bridges pub/sub between tabs and a Service Worker",
    "author": "Jim Cowart (http://ifandelse.com)",
    "license": "MIT",
    "homepage": "https://github.com/postaljs/postal.js",
    "repository": {
        "type": "git",
        "url": "git://github.com/postaljs/postal.js.git",
        "directory": "packages/postal-transport-serviceworker"
    },
    "publishConfig": {
        "access": "public"
    },
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.cts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./sw": {
            "import": {
                "types": "./dist/sw.d.mts",
                "default": "./dist/sw.mjs"
            },
            "require": {
                "types": "./dist/sw.d.cts",
                "default": "./dist/sw.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22"
    },
    "type": "module",
    "sideEffects": false,
    "keywords": [
        "postal",
        "transport",
        "serviceworker",
        "service-worker",
        "cross-tab",
        "pub/sub",
        "messaging"
    ],
    "scripts": {
        "dev": "tsdown --watch",
        "build": "tsdown",
        "test": "jest --passWithNoTests",
        "test:watch": "jest --watch",
        "lint": "eslint 'src/**/*.{ts,tsx}'"
    },
    "peerDependencies": {
        "postal": "^3.1.0"
    },
    "devDependencies": {
        "postal": "workspace:*",
        "eslint": "^9.39.2",
        "jest": "^30.2.0",
        "ts-jest": "^29.4.6",
        "tsdown": "^0.20.3",
        "typescript": "^5.9.3"
    }
}
